{
  "manifest_version": 3,
  "name": "Day Tab",
  "description": "A calm new tab: your Google Calendar day, week and month views, to-dos, a scratchpad, and the day's weather.",
  "version": "1.0",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["identity", "storage"],
  "host_permissions": ["https://www.googleapis.com/*"],
  "oauth2": {
    "client_id": "749225906117-iffcvehpjf3a1nj87300dat959n2d7qn.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.events.readonly",
      "https://www.googleapis.com/auth/calendar.calendarlist.readonly"
    ]
  }
}
